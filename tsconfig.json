{
  "compilerOptions": {
    "esModuleInterop": true,
    "target": "ESNext",
    "outDir": "./build",
    "module": "commonjs",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "types": ["jest", "node"],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": false,
    "inlineSourceMap": true,
    "inlineSources": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "typeRoots": [
      "./node_modules/@types"
    ],
    "skipLibCheck": true,
    "baseUrl": "./"
    // "rootDir": "."
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "cdk.out"
  ]
}